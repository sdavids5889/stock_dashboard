---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Dashboard from '../components/Dashboard';
import { buildDashboardData } from '../lib/dashboardData';
import fs from 'node:fs';
import path from 'node:path';

const allPosts = await getCollection('blog');
const todayStr = new Date().toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul' });

let marketStocks: import('../lib/dashboardData').MarketStock[] = [];
try {
  const marketPath = path.join(process.cwd(), 'public/data/market.json');
  const raw = JSON.parse(fs.readFileSync(marketPath, 'utf-8'));
  marketStocks = raw.stocks ?? [];
} catch {
  console.warn('market.json 로드 실패');
}

const { todayTags, todayArticles, dailySummaries, heatmapData } = buildDashboardData(
  allPosts,
  marketStocks,
  todayStr,
);
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>글로벌 마켓 요약</title>
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />
  </head>
  <body>
    <Dashboard
      client:load
      todayTags={todayTags}
      todayArticles={todayArticles}
      dailySummaries={dailySummaries}
      heatmapData={heatmapData}
    />
  </body>
</html>
