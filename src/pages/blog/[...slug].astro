---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title}</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 700px; margin: 0 auto; padding: 3rem 1.5rem; line-height: 1.8; background: #ffffff; color: #334155; }
      .back { display: inline-block; margin-bottom: 2rem; color: #64748b; text-decoration: none; font-size: 0.95rem; }
      h1 { font-size: 2rem; line-height: 1.3; color: #0f172a; margin-bottom: 0.5rem; }
      .date { color: #94a3b8; font-size: 0.9rem; margin-bottom: 2rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 1rem; }
      .content { font-size: 1.05rem; }
      /* 마크다운 내부 스타일링 */
      .content :global(h3) { color: #1e3a8a; margin-top: 2rem; font-size: 1.3rem; border-left: 4px solid #3b82f6; padding-left: 0.5rem; }
      .content :global(ol) { padding-left: 1.2rem; }
      .content :global(li) { margin-bottom: 0.7rem; }
    </style>
  </head>
  <body>
    <a href="/" class="back">← 대시보드로 돌아가기</a>
    <main>
      <h1>{entry.data.title}</h1>
      <div class="date">수집일: {entry.data.pubDate.toLocaleDateString('ko-KR')}</div>
      
      <div class="content">
        <Content /> 
      </div>
      
      <div style="margin-top: 4rem; text-align: center;">
        <a href={entry.data.sourceUrl} target="_blank" rel="noopener noreferrer" style="background: #0f172a; color: white; padding: 0.8rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 0.95rem;">
          원본 출처 기사 읽기 ↗
        </a>
      </div>
    </main>
  </body>
</html>